import streamlit as st
import requests

# FastAPI Backend URLs
UPLOAD_URL = "http://127.0.0.1:8000/upload"
ASK_URL = "http://127.0.0.1:8000/ask"

st.set_page_config(page_title="AI PDF Chatbot", layout="centered")
st.title("📄 AI PDF Chatbot (RAG)")
st.write("Upload a document and ask questions instantly.")

# --- SIDEBAR: FILE UPLOAD ---
with st.sidebar:
    st.header("1. Upload Document")
    uploaded_file = st.file_uploader("Choose a PDF file", type=["pdf"])
    
    if uploaded_file is not None:
        if st.button("Process & Index PDF"):
            with st.spinner("Processing PDF and updating vector store..."):
                # Send file to FastAPI backend
                files = {"file": (uploaded_file.name, uploaded_file.getvalue(), "application/pdf")}
                try:
                    response = requests.post(UPLOAD_URL, files=files)
                    if response.status_code == 200:
                        st.success("PDF processed successfully!")
                    else:
                        st.error(f"Backend Error: {response.json().get('error', 'Unknown error')}")
                except Exception as e:
                    st.error(f"Could not connect to backend: {e}")

# --- MAIN SCREEN: CHAT INTERFACE ---
st.header("2. Chat with your PDF")

# Initialize chat history session state
if "messages" not in st.session_state:
    st.session_state.messages = []

# Display previous chat messages
for message in st.session_state.messages:
    with st.chat_message(message["role"]):
        st.markdown(message["content"])

# User prompt input box
if user_query := st.chat_input("Ask something about the uploaded document..."):
    # Display user message
    with st.chat_message("user"):
        st.markdown(user_query)
    st.session_state.messages.append({"role": "user", "content": user_query})
    
    # Request answer from FastAPI backend
    with st.chat_message("assistant"):
        with st.spinner("Thinking..."):
            try:
                response = requests.post(ASK_URL, data={"question": user_query})
                if response.status_code == 200:
                    answer = response.json().get("answer")
                    st.markdown(answer)
                    st.session_state.messages.append({"role": "assistant", "content": answer})
                else:
                    err_msg = response.json().get("error", "Failed to generate answer.")
                    st.error(err_msg)
            except Exception as e:
                st.error(f"Communication error: {e}")
